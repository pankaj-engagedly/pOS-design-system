# Copy to .env and fill in real values
# Generate secrets with: openssl rand -hex 32

# Domain (used by Caddyfile)
DOMAIN=pos.yourdomain.com

# Database
DB_USER=pos
DB_PASS=CHANGE_ME
DB_NAME=pos

# RabbitMQ
RABBITMQ_USER=pos
RABBITMQ_PASS=CHANGE_ME

# App secrets
JWT_SECRET_KEY=CHANGE_ME
APP_SECRET_KEY=CHANGE_ME

# Docker image config
IMAGE_PREFIX=ghcr.io/pankaj-engagedly/pos
IMAGE_TAG=latest

# Optional
LOG_LEVEL=INFO
