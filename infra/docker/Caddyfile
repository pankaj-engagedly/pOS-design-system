{$DOMAIN:localhost} {
    # API requests -> gateway
    handle /api/* {
        reverse_proxy gateway:8000
    }

    # Everything else -> frontend
    handle {
        reverse_proxy frontend:80
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }
}
